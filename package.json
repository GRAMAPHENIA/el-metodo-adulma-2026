{
	"name": "el-metodo-web",
	"private": true,
	"version": "2.0.0",
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"build:static": "next build",
		"start": "pnpm dlx http-server out -p 3000 -c 31536000",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"check:no-barrels": "node scripts/check-no-barrels.mjs",
		"check": "pnpm check:no-barrels && pnpm typecheck && pnpm lint",
		"format": "prettier --write ."
	},
	"dependencies": {
		"@formspree/react": "^3.0.0",
		"clsx": "^2.1.1",
		"next": "^15.1.0",
		"radix-ui": "^1.4.3",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"react-icons": "^5.4.0",
		"resend": "^4.0.1",
		"zod": "^3.24.1"
	},
	"devDependencies": {
		"@types/node": "^22.10.2",
		"@types/react": "^19.0.2",
		"@types/react-dom": "^19.0.2",
		"autoprefixer": "^10.4.20",
		"eslint": "^9.17.0",
		"eslint-config-next": "^15.1.0",
		"postcss": "^8.4.49",
		"prettier": "^3.4.2",
		"tailwind-merge": "^2.6.1",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.7.2"
	},
	"engines": {
		"node": ">=20.11.0"
	},
	"browserslist": {
		"production": [
			"chrome >= 107",
			"edge >= 107",
			"firefox >= 104",
			"safari >= 16"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"packageManager": "pnpm@9.5.0"
}
